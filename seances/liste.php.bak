<?php
session_start();
require_once __DIR__ . "/../config/db.php";

if (!isset($_SESSION["user_id"])) {
    header("Location: /cinema/auth/auth.php");
    exit;
}

$id_film = (int)($_GET["id"] ?? 0);
if (!$id_film) {
    header("Location: /cinema/films/liste.php");
    exit;
}

// Récupérer le film
$stmt = $pdo->prepare("SELECT * FROM film WHERE id = ?");
$stmt->execute([$id_film]);
$film = $stmt->fetch(PDO::FETCH_ASSOC);
if (!$film) {
    header("Location: /cinema/films/liste.php");
    exit;
}

// Récupérer les séances disponibles (date >= aujourd'hui)
$stmt2 = $pdo->prepare("
    SELECT * FROM seance
    WHERE id_film = ? AND date >= CURDATE()
    ORDER BY date ASC, heure ASC
");
$stmt2->execute([$id_film]);
$seances = $stmt2->fetchAll(PDO::FETCH_ASSOC);

$firstName = $_SESSION["nom"] ?? "Invité";
?>
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CinéMax – <?= htmlspecialchars($film["titre"]) ?></title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        :root {
            --gold: #c9a84c; --gold-light: #e8c96d;
            --dark: #0a0a0f; --dark2: #12121a; --dark3: #1c1c28; --dark4: #252535;
            --text: #f0ede6; --text-muted: #8a8799; --red: #e63946;
        }
        body { font-family: 'DM Sans', sans-serif; background: var(--dark); color: var(--text); min-height: 100vh; }
        body::before { content:''; position:fixed; inset:0; background:radial-gradient(ellipse 80% 60% at 20% 50%, rgba(201,168,76,0.06) 0%, transparent 60%); pointer-events:none; z-index:0; }

        .filmstrip { width:100%; height:36px; background:var(--dark2); border-bottom:2px solid var(--gold); display:flex; align-items:center; overflow:hidden; position:relative; z-index:10; }
        .filmstrip-holes { display:flex; gap:18px; padding:0 12px; animation:scroll-strip 12s linear infinite; }
        .hole { width:18px; height:20px; background:var(--dark); border-radius:3px; flex-shrink:0; border:1px solid #2a2a3a; }
        @keyframes scroll-strip { from{transform:translateX(0)} to{transform:translateX(-300px)} }

        nav { position:relative; z-index:10; display:flex; justify-content:space-between; align-items:center; padding:18px 48px; background:var(--dark2); border-bottom:1px solid #2a2a3a; }
        .logo { font-family:'Playfair Display',serif; font-size:26px; font-weight:700; color:var(--gold); letter-spacing:4px; text-transform:uppercase; text-decoration:none; }
        .logo span { color:var(--red); }
        .nav-right { display:flex; align-items:center; gap:20px; }
        .welcome { font-size:14px; color:var(--text-muted); }
        .welcome strong { color:var(--gold); }
        .nav-link { color:var(--text-muted); text-decoration:none; font-size:14px; padding:6px 14px; border-radius:6px; transition:background 0.2s; }
        .nav-link:hover { background:var(--dark3); color:var(--text); }
        .logout-btn { padding:8px 20px; background:transparent; border:1px solid var(--red); color:var(--red); border-radius:6px; text-decoration:none; font-size:13px; transition:background 0.2s; }
        .logout-btn:hover { background:rgba(230,57,70,0.1); }

        main { position:relative; z-index:1; max-width:1100px; margin:0 auto; padding:48px 24px; }

        /* Film hero */
        .film-hero { display:flex; gap:36px; margin-bottom:48px; align-items:flex-start; }
        .film-poster { width:200px; flex-shrink:0; border-radius:12px; overflow:hidden; border:1px solid #2a2a3a; }
        .film-poster img { width:100%; height:280px; object-fit:cover; display:block; }
        .film-poster-placeholder { width:200px; height:280px; background:var(--dark4); display:flex; align-items:center; justify-content:center; font-size:56px; border-radius:12px; border:1px solid #2a2a3a; }
        .film-info { flex:1; }
        .back-link { display:inline-flex; align-items:center; gap:6px; color:var(--text-muted); text-decoration:none; font-size:13px; margin-bottom:16px; transition:color 0.2s; }
        .back-link:hover { color:var(--gold); }
        .film-title { font-family:'Playfair Display',serif; font-size:36px; font-weight:700; margin-bottom:12px; line-height:1.2; }
        .film-badges { display:flex; gap:10px; flex-wrap:wrap; margin-bottom:16px; }
        .badge { display:inline-block; padding:4px 12px; border-radius:20px; font-size:12px; background:var(--dark4); border:1px solid #2e2e42; color:var(--text-muted); }
        .badge-gold { background:rgba(201,168,76,0.12); border-color:rgba(201,168,76,0.3); color:var(--gold); }
        .film-synopsis { font-size:14px; color:var(--text-muted); line-height:1.7; max-width:600px; }

        /* Séances */
        .seances-title { font-family:'Playfair Display',serif; font-size:24px; margin-bottom:20px; }
        .seances-title span { color:var(--gold); }

        .seances-grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(280px, 1fr)); gap:16px; }

        .seance-card { background:var(--dark2); border:1px solid #2a2a3a; border-radius:12px; padding:20px; transition:border-color 0.2s, transform 0.2s; }
        .seance-card:hover { border-color:var(--gold); transform:translateY(-2px); }
        .seance-card.complet { opacity:0.5; pointer-events:none; }

        .seance-date { font-size:13px; color:var(--text-muted); margin-bottom:6px; }
        .seance-heure { font-family:'Playfair Display',serif; font-size:28px; font-weight:700; color:var(--gold); margin-bottom:4px; }
        .seance-salle { font-size:13px; color:var(--text-muted); margin-bottom:14px; }

        .places-bar { background:var(--dark4); border-radius:4px; height:6px; margin-bottom:8px; overflow:hidden; }
        .places-fill { height:100%; border-radius:4px; background:linear-gradient(90deg, var(--gold), var(--gold-light)); transition:width 0.3s; }
        .places-fill.low { background:linear-gradient(90deg, #e63946, #ff6b74); }

        .places-text { font-size:12px; color:var(--text-muted); margin-bottom:14px; }

        .btn-reserver { display:block; text-align:center; padding:10px; background:linear-gradient(135deg,var(--gold),var(--gold-light)); color:var(--dark); text-decoration:none; border-radius:8px; font-weight:700; font-size:13px; transition:opacity 0.2s; }
        .btn-reserver:hover { opacity:0.85; }
        .btn-complet { display:block; text-align:center; padding:10px; background:var(--dark4); color:var(--text-muted); border-radius:8px; font-size:13px; cursor:not-allowed; }

        .empty { text-align:center; padding:60px 20px; color:var(--text-muted); }
        .empty-icon { font-size:48px; margin-bottom:12px; }

        @media(max-width:640px) {
            .film-hero { flex-direction:column; }
            .film-poster { width:100%; }
            .film-poster img { height:220px; }
            nav { padding:14px 20px; }
        }
    </style>
</head>
<body>

<div class="filmstrip">
    <div class="filmstrip-holes">
        <?php for($i=0;$i<30;$i++): ?><div class="hole"></div><?php endfor; ?>
    </div>
</div>

<nav>
    <a href="/cinema/films/liste.php" class="logo">Ciné<span>Max</span></a>
    <div class="nav-right">
        <a href="/cinema/reservations/liste.php" class="nav-link">🎟️ Mes réservations</a>
        <span class="welcome">Bonjour, <strong><?= htmlspecialchars($firstName) ?></strong></span>
        <a href="/cinema/auth/logout.php" class="logout-btn">Déconnexion</a>
    </div>
</nav>

<main>
    <!-- Film hero -->
    <div class="film-hero">
        <?php if (!empty($film["affiche"])): ?>
            <div class="film-poster">
                <img src="/cinema/<?= htmlspecialchars($film["affiche"]) ?>" alt="<?= htmlspecialchars($film["titre"]) ?>">
            </div>
        <?php else: ?>
            <div class="film-poster-placeholder">🎬</div>
        <?php endif; ?>

        <div class="film-info">
            <a href="/cinema/films/liste.php" class="back-link">← Retour aux films</a>
            <h1 class="film-title"><?= htmlspecialchars($film["titre"]) ?></h1>
            <div class="film-badges">
                <?php if ($film["genre"]): ?>
                    <span class="badge badge-gold"><?= htmlspecialchars($film["genre"]) ?></span>
                <?php endif; ?>
                <?php if ($film["annee"]): ?>
                    <span class="badge"><?= $film["annee"] ?></span>
                <?php endif; ?>
                <?php if ($film["duree"]): ?>
                    <span class="badge">⏱ <?= $film["duree"] ?> min</span>
                <?php endif; ?>
            </div>
            <?php if (!empty($film["synopsis"])): ?>
                <p class="film-synopsis"><?= htmlspecialchars($film["synopsis"]) ?></p>
            <?php endif; ?>
        </div>
    </div>

    <!-- Séances -->
    <h2 class="seances-title">Séances <span>disponibles</span></h2>

    <?php if (empty($seances)): ?>
        <div class="empty">
            <div class="empty-icon">🕐</div>
            <p>Aucune séance disponible pour ce film.</p>
        </div>
    <?php else: ?>
        <div class="seances-grid">
            <?php foreach ($seances as $s):
                $pct = $s["places_total"] > 0 ? round(($s["places_dispo"] / $s["places_total"]) * 100) : 0;
                $complet = $s["places_dispo"] == 0;
                $low = $pct < 20 && !$complet;
            ?>
            <div class="seance-card <?= $complet ? 'complet' : '' ?>">
                <div class="seance-date">📅 <?= date("l d F Y", strtotime($s["date"])) ?></div>
                <div class="seance-heure"><?= substr($s["heure"], 0, 5) ?></div>
                <div class="seance-salle">📍 <?= htmlspecialchars($s["salle"]) ?></div>

                <div class="places-bar">
                    <div class="places-fill <?= $low ? 'low' : '' ?>" style="width:<?= $pct ?>%"></div>
                </div>
                <div class="places-text">
                    <?php if ($complet): ?>
                        Complet
                    <?php elseif ($low): ?>
                        ⚠️ Plus que <?= $s["places_dispo"] ?> place(s) !
                    <?php else: ?>
                        <?= $s["places_dispo"] ?> places disponibles sur <?= $s["places_total"] ?>
                    <?php endif; ?>
                </div>

                <?php if ($complet): ?>
                    <div class="btn-complet">Complet</div>
                <?php else: ?>
                    <a href="/cinema/reservations/form.php?id=<?= $s["id"] ?>" class="btn-reserver">🎟️ Réserver</a>
                <?php endif; ?>
            </div>
            <?php endforeach; ?>
        </div>
    <?php endif; ?>
</main>

</body>
</html>